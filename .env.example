# OpenAI (필수)
OPENAI_API_KEY=your_openai_api_key

# 모델
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini

# OpenAI 클라이언트 타임아웃(초)
OPENAI_TIMEOUT_SECONDS=120

# 임베딩 배치 크기 (OpenAI embeddings.create 입력 분할)
EMBEDDING_BATCH_SIZE=64

# 업로드 / 입력
MAX_UPLOAD_MB=25
MAX_QUESTION_LENGTH=4000

# 청킹
CHUNK_SIZE=900
CHUNK_OVERLAP=150

# 검색: top_k의 배수만큼 가져온 뒤 다양성 재정렬
RETRIEVAL_POOL_MULTIPLIER=2
DIVERSITY_JACCARD_THRESHOLD=0.55

# 채팅 temperature
CHAT_TEMPERATURE=0.2

# Chroma
CHROMA_DIR=chroma_db
CHROMA_COLLECTION_NAME=doctrine_collection

# 로깅 / CORS
LOG_LEVEL=INFO
# 쉼표 구분 origin, 예: http://localhost:3000,https://app.example.com
CORS_ORIGINS=*

# 프론트 (로컬 개발 시). Docker 빌드 시 compose build args로 주입 권장
NEXT_PUBLIC_API_URL=http://localhost:8000
